---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from "../components/Breadcrumbs";
import ServicesSection from "../components/ServicesSection.astro";
import SEOServicesContent from "../components/SEOServicesContent.astro";
import WhatsAppButton from "../components/WhatsAppButton";
import RecentBookingNotification from "../components/RecentBookingNotification";
---

<Layout 
  title="Resort Services | Family Resort near Nainital" 
  description="Discover premium services at Whispering Pines Resort. From guided treks and orchard walks to in-room dining and corporate event management."
>
  <div class="relative w-full bg-[#FAF9F6] text-[#2C3531] overflow-x-hidden selection:bg-[#c9a832] selection:text-[#1B3322]">
    <Breadcrumbs client:load />
    
    <main class="bg-[#FAF9F6]">
      <ServicesSection 
        hideLink={true}
        asH1={true}
        title="Your Stay in Ramgarh, Elevated — Premium Services, Real Mountain Experiences"
      />
      <SEOServicesContent />
    </main>

    <WhatsAppButton client:load />
    <RecentBookingNotification client:load />
  </div>
</Layout>
