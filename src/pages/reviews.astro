---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from "../components/Breadcrumbs";
import ReviewsHeader from "../components/ReviewsHeader";
import TestimonialList from "../components/TestimonialList";
import WhatsAppButton from "../components/WhatsAppButton";
import RecentBookingNotification from "../components/RecentBookingNotification";
---

<Layout 
  title="Guest Reviews & Testimonials | Whispering Pines Resort Ramgarh" 
  description="Read verified guest reviews for Whispering Pines Resort. See why families, couples, and corporate groups rate us the best resort in Ramgarh, Uttarakhand."
>
  <div class="relative w-full bg-[#FAF9F6] text-[#2C3531] overflow-x-hidden selection:bg-[#c9a832] selection:text-[#1B3322]">
    <Breadcrumbs client:load />
    
    <main class="pt-24 bg-[#1B3322]">
      <ReviewsHeader client:load />

      <div class="border-t border-[#FAF9F6]/10 pt-4 pb-20">
        <TestimonialList layout="grid" client:load />
      </div>
    </main>

    <WhatsAppButton client:load />
    <RecentBookingNotification client:load />
  </div>
</Layout>
