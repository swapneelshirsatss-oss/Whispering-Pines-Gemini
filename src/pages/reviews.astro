---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from "../components/Breadcrumbs";
import ReviewsHeader from "../components/ReviewsHeader";
import TestimonialList from "../components/TestimonialList";
import WhatsAppButton from "../components/WhatsAppButton";
import RecentBookingNotification from "../components/RecentBookingNotification";
---

<Layout 
  title="Guest Reviews & Testimonials | Whispering Pines Resort Ramgarh" 
  description="Read verified guest reviews for Whispering Pines Resort. See why families, couples, and corporate groups rate us the best resort in Ramgarh, Uttarakhand."
>
  <div class="relative w-full bg-[#FAF9F6] text-[#2C3531] overflow-x-hidden selection:bg-[#c9a832] selection:text-[#1B3322]">
    <Breadcrumbs client:load />
    
    <main class="pt-24 bg-[#1B3322]">
      <ReviewsHeader client:load />

      <div class="border-t border-[#FAF9F6]/10 pt-4 pb-20">
        <TestimonialList layout="grid" client:load />
      </div>
    </main>

    <WhatsAppButton client:load />
    <RecentBookingNotification client:load />
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Resort",
    "name": "Whispering Pines Resort by Casa De Bello",
    "url": "https://whisperingpinesresort.in/reviews/",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "reviewCount": "388",
      "bestRating": "5",
      "worstRating": "1"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Dr. Vikram Sethi" },
        "datePublished": "2026-05-01",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5", "worstRating": "1" },
        "reviewBody": "An absolute masterpiece of a premium villa. The panoramic Nanda Devi peaks look otherworldly from the Attic suite in the morning. Kumaoni cuisine was stellar and high-speed Wi-Fi worked seamlessly. Will return."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Priya and Rohan Sen" },
        "datePublished": "2026-04-01",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5", "worstRating": "1" },
        "reviewBody": "Whispering Pines is surrounded by massive peach trees and silent pinewood hills. The kids loved the fireplace evenings and our Golden Retriever was in absolute heaven in the safe garden lawns."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Aman Rastogi" },
        "datePublished": "2026-06-01",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5", "worstRating": "1" },
        "reviewBody": "Exceptional remote working setup. Constant 150 Mbps fiber speed, hot showers, cozy timber bed and serene fresh air. Highly recommend booking the Entire Villa for extended family stays."
      }
    ]
  })} />
</Layout>
