---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from "../components/Breadcrumbs";
import GalleryGrid from "../components/GalleryGrid";
import WhatsAppButton from "../components/WhatsAppButton";
import RecentBookingNotification from "../components/RecentBookingNotification";
import GallerySchema from "../components/GallerySchema.astro";
---

<Layout 
  title="Photo Gallery | Whispering Pines Resort Ramgarh" 
  description="Explore the photo gallery of Whispering Pines Resort in Malla Ramgarh. View our premium rooms, private villas, dining area, and 180-degree Himalayan views."
>
  <div class="relative w-full bg-[#FAF9F6] text-[#2C3531] overflow-x-hidden selection:bg-[#c9a832] selection:text-[#1B3322]">
    <Breadcrumbs client:load />
    <main class="pt-24 pb-20 bg-[#FAF9F6]">
      <GalleryGrid client:load />
    </main>
    <WhatsAppButton client:load />
    <RecentBookingNotification client:load />
  </div>
  <GallerySchema />
</Layout>
