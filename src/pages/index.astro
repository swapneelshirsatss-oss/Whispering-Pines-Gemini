---
import Layout from '../layouts/Layout.astro';
import ResortLodgingSchema from '../components/ResortLodgingSchema.astro';

import Breadcrumbs from "../components/Breadcrumbs";
import Hero from "../components/Hero";
import AboutSection from "../components/AboutSection.astro";
import RoomInventoryList from "../components/RoomInventoryList";
import AmenitiesList from "../components/AmenitiesList.astro";
import ServicesSection from "../components/ServicesSection.astro";
import LocalExperiencesList from "../components/LocalExperiencesList.astro";
import BookingInteractiveForm from "../components/BookingInteractiveForm";
import OTABadges from "../components/OTABadges.astro";
import TestimonialList from "../components/TestimonialList";
import FAQAccordion from "../components/FAQAccordion";
import WhatsAppButton from "../components/WhatsAppButton";
import RecentBookingNotification from "../components/RecentBookingNotification";

import { getImage } from "astro:assets";
import heroImgSrc from "../assets/images/Whispering-pines-balcony-view-nanital.webp";
import villaSuiteImg from "../assets/images/villa_in_nanital.avif";
import cedarSuiteImg from "../assets/images/Delux_room_Whispering_pines_mukteshwar.avif";
import orchardRoomImg from "../assets/images/Family_Twin Room_Near_nainital.avif";
import familyTwinImg from "../assets/images/Group_booking_nainital_resort.avif";

const optimizedHeroImage = await getImage({ src: heroImgSrc, format: "webp", width: 1920 });
const optVilla = await getImage({ src: villaSuiteImg, format: "webp", width: 800 });
const optCedar = await getImage({ src: cedarSuiteImg, format: "webp", width: 800 });
const optOrchard = await getImage({ src: orchardRoomImg, format: "webp", width: 800 });
const optFamily = await getImage({ src: familyTwinImg, format: "webp", width: 800 });

const roomImages = {
  "entire-cottage": optVilla.src,
  "delux-room": optCedar.src,
  "orchard-room": optOrchard.src,
  "cedar-room": optFamily.src,
};
---

<Layout 
  title="Resort in Ramgarh | Best Mountain Resort Near Nainital & Mukteshwar" 
  description="Best resort in Ramgarh Uttarakhand for families — 180° Nanda Devi views, private villa, pool & fruit orchards. Near Nainital & Mukteshwar. Book direct on WhatsApp. Best price guaranteed."
>
  <div class="relative w-full text-[#2C3531] overflow-x-hidden pb-20 md:pb-0 selection:bg-[#c9a832] selection:text-[#1B3322]">
    {/* Breadcrumb Navigation */}
    <Breadcrumbs client:load />

    {/* Hero Presentation Block */}
    <Hero client:load optimizedImage={optimizedHeroImage.src} />

    <main>
      {/* About Sanctuary Story Section */}
      <AboutSection />

      {/* Complete Room, Suite & Cottage Inventory Cards */}
      <RoomInventoryList client:visible optimizedImages={roomImages} />

      {/* General Amenities */}
      <AmenitiesList />

      {/* Premium Resort Services */}
      <ServicesSection />

      <OTABadges />

      {/* Local Destinations */}
      <LocalExperiencesList />

      {/* Booking Form */}
      <BookingInteractiveForm client:visible />

      {/* Guest Reviews */}
      <TestimonialList client:visible />

      {/* FAQ Accordion panel */}
      <FAQAccordion client:visible />
    </main>

    {/* Floating WhatsApp Button */}
    <WhatsAppButton client:idle />

    {/* Social Proof Popup */}
    <RecentBookingNotification client:load />
  </div>

  <ResortLodgingSchema />
</Layout>
