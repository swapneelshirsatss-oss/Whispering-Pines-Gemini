---
import Layout from '../../layouts/Layout.astro';
import WhatsAppButton from "../../components/WhatsAppButton";
import BlogContent from "../../components/BlogContent";
import { BLOG_POSTS, type BlogPostData } from '../../data/blogPosts.tsx';

export async function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPostData;
}

const { post } = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "image": post.imageUrl,
  "datePublished": new Date(post.date).toISOString(),
  "description": post.excerpt,
  "url": `https://whisperingpinesresort.in/blog/${post.slug}/`,
  "author": {
    "@type": "Organization",
    "name": "Whispering Pines Resort"
  }
};
---

<Layout 
  title={`${post.title} | Whispering Pines Resort Mukteshwar`}
  description={post.excerpt}
>
  <div class="relative w-full bg-[#FAF9F6] text-[#2C3531] overflow-x-hidden selection:bg-[#c9a832] selection:text-[#1B3322]">
    {/* JSON-LD Schema for SEO */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schemaData)}
    />

    <main class="pt-28 pb-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
      <div class="max-w-4xl mx-auto bg-white p-8 md:p-12 rounded-xl shadow-sm border border-[#EAE8E3]">
        <a 
          href="/blog/"
          class="text-[#c9a832] font-semibold text-sm hover:text-[#1B3322] transition-colors flex items-center mb-8 w-fit"
        >
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Journal
        </a>
        
        <div class="mb-8">
          <div class="flex items-center text-sm text-gray-500 mb-4 space-x-4">
            <span>{post.date}</span>
            <span>{post.readTime}</span>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold text-[#1B3322] mb-6 leading-tight">
            {post.title}
          </h1>
          <div class="w-full h-[300px] sm:h-[450px] overflow-hidden rounded-xl mb-10">
            <img 
              src={post.imageUrl} 
              alt={post.title} 
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        
        <div class="prose prose-lg max-w-none text-[#2C3531]">
          <BlogContent content={post.content} excerpt={post.excerpt} client:load />
        </div>
      </div>
    </main>

    <WhatsAppButton client:load />
  </div>
</Layout>
