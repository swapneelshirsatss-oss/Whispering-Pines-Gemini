---
import Layout from '../layouts/Layout.astro';

const termsContent = `
<h2>1. Acceptance of Terms</h2>
<p>By accessing and using this website, you accept and agree to be bound by the terms and provision of this agreement. In addition, when using this website's particular services, you shall be subject to any posted guidelines or rules applicable to such services.</p>

<h2>2. Booking & Cancellation Policy</h2>
<p>All bookings are subject to availability and written confirmation. To secure a reservation, a deposit may be required. Cancellation policies vary based on the season and the room rate selected. Please refer to your specific booking confirmation for exact cancellation deadlines and fees.</p>

<h2>3. Check-In & Check-Out</h2>
<ul>
  <li><strong>Check-in time:</strong> 14:00 (2:00 PM)</li>
  <li><strong>Check-out time:</strong> 11:00 AM</li>
</ul>
<p>Early check-in or late check-out is strictly subject to availability and may incur additional charges.</p>

<h2>4. Resort Rules</h2>
<p>Guests are expected to conduct themselves appropriately at all times and to comply with company procedures and/or requests with regard to conduct and respect for the property of the Resort, its employees and guests and their health and safety.</p>

<h2>5. Liability</h2>
<p>Whispering Pines Resort by Casa De Bello accepts no liability and will not pay any compensation where the performance of its obligations is prevented or affected directly or indirectly by or as a result of force majeure or any circumstances beyond its reasonable control.</p>
`;
---

<Layout
  title="Terms & Conditions | Whispering Pines Resort"
  description="Terms and conditions for booking a stay at Whispering Pines Resort in Ramgarh."
>
  <div class="pt-24 pb-20 bg-[#FAF9F6] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Header */}
      <div class="mb-12 border-b border-[#2C3531]/10 pb-8">
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-[#1B3322] mb-4">
          Terms & Conditions
        </h1>
        <p class="text-sm text-[#2C3531]/60 font-mono uppercase tracking-wider">
          Last Updated: March 1, 2024
        </p>
      </div>

      {/* Content Body */}
      <div 
        class="prose prose-lg prose-stone max-w-none 
                   prose-headings:font-display prose-headings:text-[#1B3322] prose-headings:font-bold
                   prose-p:font-sans prose-p:text-[#2C3531]/90 prose-p:leading-relaxed
                   prose-a:text-[#c9a832] prose-a:no-underline hover:prose-a:underline
                   prose-li:text-[#2C3531]/90"
        set:html={termsContent}
      />
      
    </div>
  </div>
</Layout>
