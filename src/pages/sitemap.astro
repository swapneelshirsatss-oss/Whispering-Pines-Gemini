---
import Layout from '../layouts/Layout.astro';
import { Link } from "lucide-react";

const sitemapLinks = [
  {
    category: "Main Pages",
    links: [
      { name: "Home", url: "/" },
      { name: "About Us", url: "/about-whispering-pines-resort-ramgarh" },
      { name: "Suites & Cottages", url: "/suites-cottages-ramgarh-resort" },
      { name: "Premium Villas", url: "/private-villas-near-nainital" },
      { name: "Amenities", url: "/resort-amenities-mukteshwar" },
      { name: "Services", url: "/resort-services-ramgarh" },
      { name: "Local Experiences", url: "/things-to-do-near-mukteshwar" },
      { name: "Journal & Blog", url: "/blog" },
    ]
  },
  {
    category: "Explore",
    links: [
      { name: "Photo Gallery", url: "/gallery" },
      { name: "Guest Reviews", url: "/reviews" },
      { name: "Contact Us", url: "/contact-whispering-pines-resort-mukteshwar" },
    ]
  },
  {
    category: "Journal Posts",
    links: [
      { name: "Clarks Exotica Transition", url: "/blog/clarks-exotica-transition/" },
      { name: "Ramgarh Fruit Bowl of Kumaon", url: "/blog/ramgarh-fruit-bowl-of-kumaon/" },
      { name: "Winter in the Himalayas", url: "/blog/winter-in-the-himalayas/" },
    ]
  },
  {
    category: "Legal & Policies",
    links: [
      { name: "Privacy Policy", url: "/privacy-policy" },
      { name: "Terms & Conditions", url: "/terms" },
    ]
  }
];
---

<Layout
  title="Website Sitemap | Whispering Pines Resort"
  description="Explore the full directory of pages for Whispering Pines Resort Ramgarh. Easily find rooms, amenities, policies, and contact information."
>
  <div class="pt-24 pb-20 bg-[#FAF9F6] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Header Block */}
      <div class="text-center mb-16 border-b border-[#2C3531]/10 pb-12">
        <span class="text-xs font-mono tracking-widest text-[#c9a832] uppercase flex items-center justify-center mb-3">
          <Link class="w-4 h-4 mr-2" />
          Website Directory
        </span>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-[#1B3322] mb-6">
          Sitemap
        </h1>
        <p class="text-[17px] sm:text-lg text-[#2C3531]/80 font-sans leading-relaxed max-w-2xl mx-auto">
          Find everything you need across the Whispering Pines Resort website.
        </p>
      </div>

      {/* Links Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {sitemapLinks.map((section) => (
          <div>
            <h2 class="font-display text-2xl font-bold text-[#1B3322] mb-6 flex items-center">
              <div class="w-6 h-[2px] bg-[#c9a832] mr-3" />
              {section.category}
            </h2>
            <ul class="space-y-4">
              {section.links.map((link) => (
                <li>
                  <a 
                    href={link.url}
                    class="text-[#2C3531]/80 font-sans hover:text-[#c9a832] transition-colors flex items-center group"
                  >
                    <span class="w-1.5 h-1.5 rounded-full bg-[#c9a832]/30 group-hover:bg-[#c9a832] mr-3 transition-colors" />
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>
  </div>
</Layout>
